# Bear Trap Frontend — Environment Variables
# Copy to .env.local and fill in values.

# ── Environment ──────────────────────────────────────────
NEXT_PUBLIC_ENVIRONMENT=testnet       # testnet or mainnet

# ── Contract Addresses (from deployment) ─────────────────
NEXT_PUBLIC_BEAR_TRAP_ADDRESS=0x...
NEXT_PUBLIC_OSO_TOKEN_ADDRESS=0x...   # MockOSO on testnet, real $OSO on mainnet

# ── Enforcer Addresses ───────────────────────────────────
NEXT_PUBLIC_ZKP_ENFORCER_ADDRESS=0x...  # ZKPEnforcer contract — needed for prize redemption

# ── Backend ──────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ── Web3Auth ─────────────────────────────────────────────
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here   # From https://dashboard.web3auth.io
