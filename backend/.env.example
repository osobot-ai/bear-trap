# Bear Trap Backend — Environment Variables
# Copy to .env and fill in values.

# ── Database ──────────────────────────────────────────────
DATABASE_PATH=./data/puzzles.db

# ── Server ────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000   # CORS origin (* = allow all)
ENVIRONMENT=testnet                   # testnet or mainnet

# ── Blockchain (required) ────────────────────────────────
RPC_URL=https://sepolia.base.org
BEAR_TRAP_ADDRESS=0x...               # Deployed BearTrap contract
ZKP_ENFORCER_ADDRESS=0x...            # Deployed ZKPEnforcer contract

# ── Wallets (required) ───────────────────────────────────
OPERATOR_PRIVATE_KEY=0x...            # Operator wallet — calls useTicket()
BOUNDLESS_PRIVATE_KEY=0x...           # Wallet for Boundless proof requests (mainnet only)

# ── Optional ─────────────────────────────────────────────
PINATA_JWT=                           # For uploading guest ELF to IPFS (mainnet only)
